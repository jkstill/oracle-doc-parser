#!/usr/bin/env python3
"""
oracle-rag — CLI for Oracle documentation RAG retrieval

Usage examples:

  # Index embeddings (run once per database)
  oracle-rag embed --ollama-url http://lestrade:11434
  oracle-rag embed --ollama-url http://lestrade:11434 --db dict    # dict only
  oracle-rag embed --ollama-url http://lestrade:11434 --db plsql   # plsql only

  # Search
  oracle-rag search "session wait events" --limit 5
  oracle-rag lookup DBA_SEGMENTS
  oracle-rag lookup DBMS_STATS.GATHER_TABLE_STATS
  oracle-rag package DBMS_STATS --compact
  oracle-rag views 'DBA_HIST_%'
  oracle-rag related DBA_SEGMENTS
  oracle-rag stats

  # Ask an LLM (uses hybrid vector+FTS5 search if embeddings available)
  oracle-rag ask --ollama-url http://lestrade:11434 --model qwen2.5:14b \\
      "write a query to show which sessions are waiting and on what events"

  oracle-rag ask --ollama-url http://lestrade:11434 --model qwen2.5:14b \\
      --include 'V$SESSION,V$SESSION_WAIT' \\
      "write a query to show which sessions are waiting and on what events"

  # List available Ollama models
  oracle-rag models --ollama-url http://lestrade:11434
"""

import argparse
import json
import sys
from pathlib import Path

from oracle_rag.retriever import OracleRetriever, RetrievalConfig, RetrievalResult, Chunk
from oracle_rag.backends import make_backend


# ---------------------------------------------------------------------------
# Output formatters
# ---------------------------------------------------------------------------

def format_chunks_md(chunks, title, compact=False):
    lines = [f"# {title}", ""]
    for chunk in chunks:
        lines.append(chunk.to_markdown(compact=compact))
        lines.append("")
    return "\n".join(lines)


def format_chunks_json(chunks):
    return json.dumps([c.to_dict() for c in chunks], indent=2, ensure_ascii=False)


# ---------------------------------------------------------------------------
# Hybrid search helper — used by search and ask commands
# ---------------------------------------------------------------------------

def _make_hybrid_searcher(db_path, ollama_url, embed_model, alpha=0.6):
    """
    Try to build a HybridSearcher for a database.
    Returns None if embeddings table is missing or empty.
    """
    from oracle_rag.embeddings import HybridSearcher, EmbeddingClient
    import sqlite3
    try:
        con = sqlite3.connect(db_path)
        count = con.execute(
            "SELECT COUNT(*) FROM embeddings"
        ).fetchone()[0]
        con.close()
        if count == 0:
            return None
    except sqlite3.OperationalError:
        return None

    client = EmbeddingClient(ollama_url, model=embed_model)
    return HybridSearcher(db_path, client, alpha=alpha)


# ---------------------------------------------------------------------------
# Command handlers
# ---------------------------------------------------------------------------

def cmd_embed(args, _ret):
    """Generate and store embeddings for all chunks in one or both databases."""
    from oracle_rag.embeddings import EmbeddingClient, index_database

    # Build config to find DB paths
    try:
        if args.base_dir:
            ver = args.db_version if args.db_version != "auto" else "19c"
            config = RetrievalConfig.from_directory(args.base_dir, ver)
        else:
            config = RetrievalConfig(dict_db=args.dict_db, plsql_db=args.plsql_db)
    except Exception as e:
        print(f"Configuration error: {e}", file=sys.stderr)
        sys.exit(1)

    client = EmbeddingClient(
        base_url=args.ollama_url,
        model=args.embed_model,
        batch_size=args.batch_size,
    )

    # Test connection and report dimensions
    print(f"Connecting to {args.ollama_url} model={args.embed_model} ...")
    try:
        dims = client.check_connection()
        print(f"OK — embedding dimension: {dims}")
    except ConnectionError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    dbs = []
    if args.db in ("dict", "both") and config.dict_db:
        dbs.append(("data-dictionary", config.dict_db))
    if args.db in ("plsql", "both") and config.plsql_db:
        dbs.append(("pl-sql", config.plsql_db))

    if not dbs:
        print("No databases found to index.", file=sys.stderr)
        sys.exit(1)

    for label, db_path in dbs:
        print(f"\nIndexing {label}: {db_path}")

        last_pct = [-1]
        def progress(current, total, name):
            pct = int(100 * current / total)
            if pct != last_pct[0] and pct % 5 == 0:
                print(f"  {pct:3d}%  [{current}/{total}]  {name[:60]}")
                last_pct[0] = pct

        stats = index_database(
            db_path=db_path,
            client=client,
            force=args.force,
            progress_cb=progress,
        )
        print(f"  Done: {stats['embedded']} embedded, "
              f"{stats['skipped']} skipped, "
              f"{stats['failed']} failed")


def cmd_search(args, ret):
    query = " ".join(args.query)
    version = args.db_version if args.db_version != "auto" else None

    # Use hybrid search if embeddings available and ollama_url provided
    ollama_url = getattr(args, "ollama_url", None)
    embed_model = getattr(args, "embed_model", "mxbai-embed-large:latest")

    if ollama_url and _embeddings_available(ret, args):
        from oracle_rag.embeddings import EmbeddingClient, HybridSearcher
        client = EmbeddingClient(ollama_url, model=embed_model)
        dict_chunks, plsql_chunks = [], []

        if not args.plsql_only and ret.config.dict_db:
            hs = _make_hybrid_searcher(ret.config.dict_db, ollama_url, embed_model)
            if hs:
                with hs:
                    dict_chunks = hs.search(query, limit=args.limit, version=version)

        if not args.dict_only and ret.config.plsql_db:
            hs = _make_hybrid_searcher(ret.config.plsql_db, ollama_url, embed_model)
            if hs:
                with hs:
                    plsql_chunks = hs.search(query, limit=args.limit, version=version)

        from oracle_rag.retriever import RetrievalResult
        result = RetrievalResult(query=query, dict_chunks=dict_chunks, plsql_chunks=plsql_chunks)
    else:
        result = ret.search(
            query, limit=args.limit, version=version,
            dict_only=args.dict_only, plsql_only=args.plsql_only,
        )

    if result.total == 0:
        print(f"No results found for: {query}", file=sys.stderr)
        sys.exit(1)

    if args.format == "json":
        print(json.dumps(result.to_dict(), indent=2, ensure_ascii=False))
    else:
        print(result.to_markdown(compact=args.compact))


def _embeddings_available(ret, args) -> bool:
    """Quick check: do any embeddings exist in either DB?"""
    import sqlite3
    for db_path in [ret.config.dict_db, ret.config.plsql_db]:
        if not db_path:
            continue
        try:
            con = sqlite3.connect(db_path)
            count = con.execute("SELECT COUNT(*) FROM embeddings").fetchone()[0]
            con.close()
            if count > 0:
                return True
        except sqlite3.OperationalError:
            pass
    return False


def cmd_lookup(args, ret):
    chunks = ret.lookup_many(args.names)
    not_found = set(args.names) - {c.name for c in chunks}
    for name in not_found:
        print(f"Not found: {name}", file=sys.stderr)
    if not chunks:
        sys.exit(1)
    title = f"Oracle Documentation: {', '.join(c.name for c in chunks)}"
    if args.format == "json":
        print(format_chunks_json(chunks))
    else:
        print(format_chunks_md(chunks, title, compact=args.compact))


def cmd_package(args, ret):
    package = args.package_name.upper()
    chunks = ret.package_subprograms(
        package,
        version=args.db_version if args.db_version != "auto" else None,
    )
    if not chunks:
        chunk = ret.lookup(package)
        chunks = [chunk] if chunk else []
    if not chunks:
        print(f"Package not found: {package}", file=sys.stderr)
        sys.exit(1)
    title = f"Package: {package} ({len(chunks)} subprograms)"
    if args.format == "json":
        print(format_chunks_json(chunks))
    else:
        print(format_chunks_md(chunks, title, compact=args.compact))


def cmd_views(args, ret):
    chunks = ret.views_like(
        args.pattern,
        version=args.db_version if args.db_version != "auto" else None,
        limit=args.limit,
    )
    if not chunks:
        print(f"No views found matching: {args.pattern}", file=sys.stderr)
        sys.exit(1)
    title = f"Views matching: {args.pattern} ({len(chunks)} results)"
    if args.format == "json":
        print(format_chunks_json(chunks))
    else:
        print(format_chunks_md(chunks, title, compact=args.compact))


def cmd_related(args, ret):
    name = args.view_name.upper()
    target = ret.lookup(name)
    related = ret.related_views(name)
    chunks = ([target] if target else []) + related
    if not chunks:
        print(f"View not found: {name}", file=sys.stderr)
        sys.exit(1)
    title = f"View family: {name}"
    if args.format == "json":
        print(format_chunks_json(chunks))
    else:
        print(format_chunks_md(chunks, title, compact=args.compact))


def cmd_stats(args, ret):
    stats = ret.stats()
    if args.format == "json":
        print(json.dumps(stats, indent=2))
        return
    for label, data in stats.items():
        if data is None:
            print(f"{label}: not configured")
            continue
        print(f"\n=== {label} ({data['total']} chunks) ===")
        print(f"Versions: {', '.join(data['versions'])}")
        for obj_type, count in data["types"].items():
            print(f"  {count:5d}  {obj_type}")

    # Show embedding coverage if available
    import sqlite3
    for label, db_path in [("dict", ret.config.dict_db), ("plsql", ret.config.plsql_db)]:
        if not db_path:
            continue
        try:
            con = sqlite3.connect(db_path)
            rows = con.execute(
                "SELECT model, COUNT(*) FROM embeddings GROUP BY model"
            ).fetchall()
            con.close()
            for model, count in rows:
                print(f"\n  {label} embeddings: {count} vectors ({model})")
        except sqlite3.OperationalError:
            pass


def cmd_models(args, _ret):
    from oracle_rag.backends import OllamaBackend
    url = args.ollama_url or "http://localhost:11434"
    try:
        backend = OllamaBackend(url, model="none")
        models = backend.list_models()
        if not models:
            print("No models found.")
        for m in models:
            print(m)
    except ConnectionError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_claude_models(args, _ret):
    """List available Claude models from the Anthropic API."""
    import os
    from oracle_rag.backends import ClaudeBackend
    if not os.environ.get("ANTHROPIC_API_KEY"):
        print("Error: ANTHROPIC_API_KEY is not set.", file=sys.stderr)
        sys.exit(1)
    try:
        b = ClaudeBackend()
        models = b.list_models()
        for m in models:
            print(m)
    except (ConnectionError, ValueError) as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_ask(args, ret):
    question = " ".join(args.question)
    version = args.db_version if args.db_version != "auto" else None
    ollama_url = getattr(args, "ollama_url", None)
    embed_model = getattr(args, "embed_model", "mxbai-embed-large:latest")

    # Try hybrid search if embeddings are available
    use_hybrid = ollama_url and _embeddings_available(ret, args)

    if use_hybrid:
        print("[hybrid vector+FTS5 search]", file=sys.stderr)
        from oracle_rag.retriever import RetrievalResult
        dict_chunks, plsql_chunks = [], []

        if not args.plsql_only and ret.config.dict_db:
            hs = _make_hybrid_searcher(ret.config.dict_db, ollama_url, embed_model)
            if hs:
                with hs:
                    dict_chunks = hs.search(question, limit=args.limit, version=version)

        if not args.dict_only and ret.config.plsql_db:
            hs = _make_hybrid_searcher(ret.config.plsql_db, ollama_url, embed_model)
            if hs:
                with hs:
                    plsql_chunks = hs.search(question, limit=args.limit, version=version)

        result = RetrievalResult(
            query=question,
            dict_chunks=dict_chunks,
            plsql_chunks=plsql_chunks,
        )
    else:
        print("[FTS5 keyword search]", file=sys.stderr)
        result = ret.search(
            question, limit=args.limit, version=version,
            dict_only=args.dict_only, plsql_only=args.plsql_only,
        )

    if result.total == 0:
        print("Warning: no documentation context found for this query.", file=sys.stderr)

    # --include: force-add specific views/subprograms to context
    include_arg = getattr(args, "include", None) or ""
    include_names = [n.strip() for n in include_arg.split(",") if n.strip()]
    if include_names:
        extra = ret.lookup_many(include_names)
        not_found = set(include_names) - {c.name for c in extra}
        for name in not_found:
            print(f"Warning: --include {name!r} not found", file=sys.stderr)
        existing_ids = {c.id for c in result.all_chunks}
        for chunk in extra:
            if chunk.id not in existing_ids:
                if chunk.is_view:
                    result.dict_chunks.append(chunk)
                else:
                    result.plsql_chunks.append(chunk)

    context_md = result.to_markdown(compact=args.compact)
    prompt = _build_prompt(question, context_md, args.task)

    if args.show_prompt:
        print("=== PROMPT ===", file=sys.stderr)
        print(prompt, file=sys.stderr)
        print("=== END PROMPT ===\n", file=sys.stderr)

    try:
        backend = make_backend(
            backend=args.backend,
            ollama_url=ollama_url,
            model=getattr(args, "model", None),
            gemini_cli=getattr(args, "gemini_cli", "gemini"),
            timeout=args.timeout,
        )
    except ValueError as e:
        print(f"Backend error: {e}", file=sys.stderr)
        sys.exit(1)

    print(f"[{backend.name()}]", file=sys.stderr)

    try:
        response = backend.generate(prompt)
    except (ConnectionError, RuntimeError, TimeoutError) as e:
        print(f"LLM error: {e}", file=sys.stderr)
        sys.exit(1)

    print(response)


def _build_prompt(question, context, task):
    if task == "sql":
        instruction = (
            "Using ONLY the Oracle documentation provided below as context, "
            "write a SQL query that answers the question.\n\n"
            "STRICT RULES:\n"
            "- Use ONLY the exact view names shown in the documentation headings.\n"
            "- Use ONLY the exact column names from the Columns tables in the documentation.\n"
            "- Do NOT infer, guess, or rename columns. The column description is not the column name.\n"
            "- If a column description says 'Oracle username', the column name is whatever appears "
            "in the Column field of the table, not the description.\n"
            "- If the documentation does not contain enough information, say so explicitly."
        )
    elif task == "explain":
        instruction = (
            "Using the Oracle documentation provided below as context, "
            "explain the answer to the question in clear terms. "
            "Reference specific views, columns, or package subprograms by name."
        )
    elif task == "plsql":
        instruction = (
            "Using ONLY the Oracle documentation provided below as context, "
            "write a PL/SQL code block that addresses the question.\n\n"
            "STRICT RULES:\n"
            "- Use ONLY the exact package names and procedure/function names shown in the documentation.\n"
            "- Use ONLY the exact parameter names from the Parameters tables in the documentation.\n"
            "- Do NOT infer or guess parameter names from their descriptions.\n"
            "- If insufficient context is available, say so explicitly."
        )
    else:
        instruction = (
            "Using the Oracle documentation provided below as context, "
            "answer the following question. "
            "Be specific and reference Oracle object names where relevant."
        )

    return f"""{instruction}

Question: {question}

--- Oracle Documentation Context ---
{context}
--- End Context ---
"""


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def build_parser():
    # Shared options inherited by all subcommands
    shared = argparse.ArgumentParser(add_help=False)
    shared.add_argument("--dict-db", metavar="PATH")
    shared.add_argument("--plsql-db", metavar="PATH")
    shared.add_argument("--base-dir", metavar="PATH")
    shared.add_argument("--db-version", metavar="VER", default="auto")
    shared.add_argument("--format", choices=["markdown", "json"], default="markdown")
    shared.add_argument("--compact", action="store_true")
    shared.add_argument("--limit", type=int, default=5, metavar="N")

    parser = argparse.ArgumentParser(
        prog="oracle-rag",
        description="Oracle documentation RAG retrieval CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
        parents=[shared],
    )

    sub = parser.add_subparsers(dest="command", required=True)

    # embed
    p = sub.add_parser("embed", parents=[shared],
                       help="Generate and store embeddings for all chunks")
    p.add_argument("--ollama-url", metavar="URL", default="http://localhost:11434",
                   help="Ollama server URL")
    p.add_argument("--embed-model", metavar="MODEL",
                   default="mxbai-embed-large:latest",
                   help="Embedding model (default: mxbai-embed-large:latest)")
    p.add_argument("--db", choices=["dict", "plsql", "both"], default="both",
                   help="Which database(s) to index (default: both)")
    p.add_argument("--batch-size", type=int, default=32, metavar="N",
                   help="Embedding batch size (default: 32)")
    p.add_argument("--force", action="store_true",
                   help="Re-embed chunks even if already embedded")

    # search
    p = sub.add_parser("search", parents=[shared])
    p.add_argument("query", nargs="+")
    p.add_argument("--dict-only", action="store_true")
    p.add_argument("--plsql-only", action="store_true")
    p.add_argument("--ollama-url", metavar="URL",
                   help="Ollama URL for hybrid search (optional)")
    p.add_argument("--embed-model", metavar="MODEL",
                   default="mxbai-embed-large:latest")

    # lookup
    p = sub.add_parser("lookup", parents=[shared])
    p.add_argument("names", nargs="+", metavar="NAME")

    # package
    p = sub.add_parser("package", parents=[shared])
    p.add_argument("package_name", metavar="PACKAGE")

    # views
    p = sub.add_parser("views", parents=[shared])
    p.add_argument("pattern")

    # related
    p = sub.add_parser("related", parents=[shared])
    p.add_argument("view_name", metavar="VIEW")

    # stats
    sub.add_parser("stats", parents=[shared])

    # models
    p = sub.add_parser("models", help="List available Ollama models")
    p.add_argument("--ollama-url", metavar="URL", default="http://localhost:11434")

    # claude-models
    sub.add_parser("claude-models", help="List available Claude models (requires ANTHROPIC_API_KEY)")

    # ask
    p = sub.add_parser("ask", parents=[shared])
    p.add_argument("question", nargs="+")
    p.add_argument("--backend", choices=["ollama", "gemini", "claude"], default="ollama")
    p.add_argument("--ollama-url", metavar="URL", default=None,
                   help="Ollama server URL -- required for ollama backend and hybrid search")
    p.add_argument("--model", metavar="MODEL",
                   help="LLM model name for generation (e.g. qwen2.5:14b)")
    p.add_argument("--embed-model", metavar="MODEL",
                   default="mxbai-embed-large:latest",
                   help="Embedding model for hybrid search")
    p.add_argument("--gemini-cli", metavar="PATH", default="gemini")
    p.add_argument("--task", choices=["sql", "plsql", "explain", "general"],
                   default="sql")
    p.add_argument("--timeout", type=int, default=120)
    p.add_argument("--dict-only", action="store_true")
    p.add_argument("--plsql-only", action="store_true")
    p.add_argument("--include", metavar="NAME[,NAME...]",
                   help="Force-include views/subprograms by name (comma-separated)")
    p.add_argument("--show-prompt", action="store_true",
                   help="Print full prompt to stderr before sending")
    p.add_argument("--alpha", type=float, default=0.6, metavar="F",
                   help="Vector weight in hybrid search 0.0-1.0 (default 0.6)")

    return parser


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = build_parser()
    args = parser.parse_args()

    # Commands that don't need a database connection
    if args.command == "models":
        cmd_models(args, None)
        return

    if args.command == "embed":
        cmd_embed(args, None)
        return

    if args.command == "claude-models":
        cmd_claude_models(args, None)
        return

    # Build config for all other commands
    try:
        if args.base_dir:
            ver = args.db_version if args.db_version != "auto" else "19c"
            config = RetrievalConfig.from_directory(args.base_dir, ver)
        else:
            config = RetrievalConfig(dict_db=args.dict_db, plsql_db=args.plsql_db)
    except Exception as e:
        print(f"Configuration error: {e}", file=sys.stderr)
        sys.exit(1)

    try:
        with OracleRetriever(config) as ret:
            dispatch = {
                "search":  cmd_search,
                "lookup":  cmd_lookup,
                "package": cmd_package,
                "views":   cmd_views,
                "related": cmd_related,
                "stats":   cmd_stats,
                "ask":     cmd_ask,
            }
            dispatch[args.command](args, ret)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except BrokenPipeError:
        sys.exit(0)


if __name__ == "__main__":
    main()
